# Base URL for the Next.js backend (no trailing slash). Leave empty for same-origin.
NEXT_PUBLIC_API_URL=http://127.0.0.1:3000

# Session signing (min 16 chars). Required in production.
AUTH_SECRET=change-this-to-a-long-random-string

# Next.js Backend B runtime configuration
MONGODB_URI=
PYTHON_SERVICE_URL=http://127.0.0.1:5000
PYTHON_RANK_PATH=/api/rank
SCREENING_TIMEOUT_MS=120000

# Stripe (optional until billing rollout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
STRIPE_PRICE_BASIC_CENTS=2900
STRIPE_PRICE_GROWTH_CENTS=9900

# Security controls
RATE_LIMIT_AUTH_PER_MIN=30
RATE_LIMIT_SCREENING_PER_MIN=20
ENFORCE_CSRF=false